# ---- App ----
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256

# ---- MongoDB Atlas ----
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=mood_capsule

# ---- Google Gemini ----
# Get a free-tier key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# Free-tier friendly default. "gemini-2.0-flash" also works well and is even cheaper/faster.
GEMINI_MODEL=gemini-2.5-flash

# ---- TMDB (Movies / TV) ----
TMDB_API_KEY=your_tmdb_v3_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/w500

# ---- Google Books ----
GOOGLE_BOOKS_API_KEY=your_google_books_api_key

# ---- Spotify ----
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ---- Listen Notes (optional, podcasts) ----
LISTEN_NOTES_API_KEY=your_listen_notes_api_key
